  "field_rights": {},
  "row_conditions": {
    "FRS_MyItem#": {
      "_comment": "Preserved exactly as ISM stores it - not rebuilt by the script",
      "type": "preserve_ootb"
    },
    "Incident#": {
      "_comment": "3-leaf Or - user can see records they created, own, or are the subject of",
      "type": "or_group",
      "permission": "write",
      "conditions": [
        {
          "kind": "function",
          "field": "CreatedBy",
          "fn": "CurrentLoginId"
        },
        {
          "kind": "function",
          "field": "Owner",
          "fn": "CurrentLoginId"
        },
        {
          "kind": "function",
          "field": "ProfileLink_RecID",
          "fn": "CurrentUserRecId"
        }
      ]
    },
    "ServiceReq#": {
      "_comment": "Same 3-leaf Or as Incident# - SR can be raised on a user's behalf",
      "type": "or_group",
      "permission": "write",
      "conditions": [
        {
          "kind": "function",
          "field": "CreatedBy",
          "fn": "CurrentLoginId"
        },
        {
          "kind": "function",
          "field": "Owner",
          "fn": "CurrentLoginId"
        },
        {
          "kind": "function",
          "field": "ProfileLink_RecID",
          "fn": "CurrentUserRecId"
        }
      ]
    },
    "MyShelfItem#": {
      "type": "single",
      "permission": "write",
      "kind": "function",
      "field": "CreatedBy",
      "fn": "CurrentLoginId"
    },
    "FRS_Knowledge#": {
      "_comment": "Write-permission filter - keeps unpublished drafts invisible",
      "type": "single",
      "permission": "write",
      "kind": "literal",
      "field": "Status",
      "value": "Published",
      "valueType": "string"
    },
    "Announcement#": {
      "_comment": "Read-permission filter - only Published announcements shown on portal",
      "type": "single",
      "permission": "read",
      "kind": "literal",
      "field": "Status",
      "value": "Published",
      "valueType": "string"
    },
    "Journal#": {
      "_comment": "Or group - user sees journals they created or any published-to-web entry",
      "type": "or_group",
      "permission": "write",
      "conditions": [
        {
          "kind": "function",
          "field": "CreatedBy",
          "fn": "CurrentLoginId"
        },
        {
          "kind": "literal",
          "field": "PublishToWeb",
          "value": true,
          "valueType": "boolean"
        }
      ]
    },
    "Journal#Email": {
      "_comment": "Or group - user sees journals they created or any published-to-web entry",
      "type": "single",
      "permission": "write",
      "kind": "literal",
      "field": "PublishToWeb",
      "value": true,
      "valueType": "boolean"
    },
    "Journal#Notes": {
      "_comment": "Or group - user sees journals they created or any published-to-web entry",
      "type": "single",
      "permission": "write",
      "kind": "literal",
      "field": "PublishToWeb",
      "value": true,
      "valueType": "boolean"
    }
  }
